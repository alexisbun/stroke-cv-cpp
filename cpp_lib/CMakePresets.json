{
    "version": 6,
    "configurePresets": [
        {
            "name": "debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "relwithdebinfo",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/relwithdebinfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "android-base",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
                "VCPKG_KEEP_ENV_VARS": "ANDROID_NDK_HOME",
                "ANDROID_PLATFORM": "android-30",
                "ANDROID_STL": "c++_static"
            }
        },
        {
            "name": "android-debug",
            "hidden": true,
            "inherits": "android-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "android-release",
            "hidden": true,
            "inherits": "android-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "android-arm64-debug",
            "inherits": "android-debug",
            "binaryDir": "${sourceDir}/build/arm64-v8a-debug",
            "cacheVariables": {
                "ANDROID_ABI": "arm64-v8a",
                "VCPKG_TARGET_TRIPLET": "arm64-android"
            }
        },
        {
            "name": "android-arm64-release",
            "inherits": "android-release",
            "binaryDir": "${sourceDir}/build/arm64-v8a-release",
            "cacheVariables": {
                "ANDROID_ABI": "arm64-v8a",
                "VCPKG_TARGET_TRIPLET": "arm64-android"
            }
        },
        {
            "name": "android-arm32-debug",
            "inherits": "android-debug",
            "binaryDir": "${sourceDir}/build/armeabi-v7a-debug",
            "cacheVariables": {
                "ANDROID_ABI": "armeabi-v7a",
                "VCPKG_TARGET_TRIPLET": "arm-android"
            }
        },
        {
            "name": "android-arm32-release",
            "inherits": "android-release",
            "binaryDir": "${sourceDir}/build/armeabi-v7a-release",
            "cacheVariables": {
                "ANDROID_ABI": "armeabi-v7a",
                "VCPKG_TARGET_TRIPLET": "arm-android"
            }
        },
        {
            "name": "android-x64-debug",
            "inherits": "android-debug",
            "binaryDir": "${sourceDir}/build/x86_64-debug",
            "cacheVariables": {
                "ANDROID_ABI": "x86_64",
                "VCPKG_TARGET_TRIPLET": "x64-android"
            }
        },
        {
            "name": "android-x64-release",
            "inherits": "android-release",
            "binaryDir": "${sourceDir}/build/x86_64-release",
            "cacheVariables": {
                "ANDROID_ABI": "x86_64",
                "VCPKG_TARGET_TRIPLET": "x64-android"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "relwithdebinfo",
            "configurePreset": "relwithdebinfo"
        },
        {
            "name": "android-arm64-debug",
            "configurePreset": "android-arm64-debug"
        },
        {
            "name": "android-arm64-release",
            "configurePreset": "android-arm64-release"
        },
        {
            "name": "android-arm32-debug",
            "configurePreset": "android-arm32-debug"
        },
        {
            "name": "android-arm32-release",
            "configurePreset": "android-arm32-release"
        },
        {
            "name": "android-x64-debug",
            "configurePreset": "android-x64-debug"
        },
        {
            "name": "android-x64-release",
            "configurePreset": "android-x64-release"
        }
    ]
}